{
  "id": "9.20-chloroform",
  "category": "NAFI6 H-9.20",
  "name": "Xác định dư lượng Chloroform - GC-MS/MS",
  "ref": "Clinical Chemistry, Vol 26, No. 1, 1980",
  "version": 3,
  "inputs": [
    {
      "var": "n_sample",
      "label": "Số lượng mẫu",
      "type": "number",
      "default": 1,
      "step": 1,
      "unitLabel": "mẫu"
    },
    {
      "var": "n_qc",
      "label": "Số lượng QC",
      "type": "number",
      "default": 8,
      "step": 1,
      "unitLabel": "mẫu"
    },
    {
      "var": "loai_mau",
      "label": "Loại nền mẫu",
      "type": "select",
      "default": "Thực phẩm",
      "options": [
        { "value": "Thực phẩm", "label": "Thực phẩm" },
        { "value": "Nước sạch", "label": "Nước sạch" }
      ]
    }
  ],
  "variables": {
    "total_n": "n_sample + n_qc"
  },
  "consumables": [
    {
      "name": "cyclohexan",
      "_displayName": "Dung môi Cyclohexan (PA)",
      "formula": "5 * total_n + 37",
      "unit": "ml",
      "type": "simple",
      "base_note": "5ml/mẫu + 37ml pha các dung dịch chuẩn từ đầu đến dựng đường chuẩn (20ml pha chuẩn gốc 1mg/mL + 10ml pha chuẩn trung gian 10ug/mL + 0.9ml pha chuẩn trung gian 1000ng/mL + 0.9ml pha chuẩn làm việc 100ng/mL + 5.13ml pha C0-C5 + hao hụt)"
    },
    {
      "name": "psa",
      "_displayName": "Bột PSA (Làm sạch mẫu)",
      "formula": "0.25 * total_n",
      "unit": "g",
      "type": "simple",
      "condition": "loai_mau === 'Thực phẩm'",
      "base_note": "Chỉ dùng cho nền Thực phẩm"
    },
    {
      "name": "c18",
      "_displayName": "Bột C18 (Làm sạch mẫu)",
      "formula": "0.25 * total_n",
      "unit": "g",
      "type": "simple",
      "condition": "loai_mau === 'Thực phẩm'",
      "base_note": "Chỉ dùng cho nền Thực phẩm"
    },
    {
      "name": "nuoc_cat",
      "_displayName": "Nước cất 2 lần",
      "formula": "5 * total_n",
      "unit": "ml",
      "type": "simple",
      "condition": "loai_mau === 'Thực phẩm'",
      "base_note": "Chỉ dùng cho nền Thực phẩm"
    },
    {
      "name": "chloroform_pa_std",
      "_displayName": "Chất chuẩn Chloroform PA (Gốc)",
      "formula": "20",
      "unit": "mg",
      "type": "simple",
      "base_note": "Tiêu hao cố định 20 mg mỗi mẻ để pha mới hoàn toàn dung dịch chuẩn gốc 1 mg/mL"
    }
  ],
  "targets": [
    {
      "id": "chloroform",
      "name": "Chloroform",
      "unit": "ppb",
      "lod": "2 ppb",
      "loq": "5 ppb"
    }
  ]
}
