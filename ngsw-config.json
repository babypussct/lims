{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.23-b22",
    "notesVersion": "v26.07.23-b22",
    "title": "Data Cleanup: Điều Chỉnh CAS Lỗi & Hoàn Tác Theo Phiên",
    "features": [
      "📄 Phân Trang Theo Từng Nhóm CAS hoặc Từng Hồ Sơ Lỗi, Giảm Quá Tải và Nguy Cơ Chọn Nhầm",
      "🧹 Mở Trực Tiếp 128 Nhãn Giữ Chỗ, 32 CAS Dạng Ngày và 3 CAS Lỗi Khác để Điều Chỉnh",
      "✅ Kiểm Tra Cấu Trúc, Checksum và Đối Chiếu PubChem Trước Khi Lưu CAS",
      "↩️ Hoàn Tác Theo Phiên Cho Cả Danh Pháp, CAS và Metadata Chuẩn Hóa"
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
