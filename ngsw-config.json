{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.23-b20",
    "title": "Chuẩn Hóa Tiếng Việt và Biểu Tượng Toàn Hệ Thống",
    "features": [
      "✍️ Biên Tập Lại Nội Dung Tiếng Việt Theo Ngữ Cảnh Phòng Thí Nghiệm",
      "🔤 Áp Dụng Title Case Nhất Quán cho Menu, Tiêu Đề và Nút Chính",
      "🎯 Đồng Bộ Biểu Tượng Font Awesome và Khắc Phục Toàn Bộ Icon Không Hợp Lệ"
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
