{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.24-b02",
    "notesVersion": "v26.07.24-b02",
    "title": "Mở Khóa Trạm Pha Chế, Chuẩn Hóa Cảnh Báo & Đếm Ngược Cập Nhật",
    "features": [
      "🔓 Mở khóa Trạm Pha Chế ở chế độ Sandbox cho toàn bộ nhân viên",
      "🛡️ Chuẩn hóa toàn bộ thông báo từ chối quyền sang tiếng Việt thống nhất",
      "⏳ Đếm ngược 30s tự động tạm dừng ở 10s nếu máy không tương tác, tiếp tục đếm khi di chuột/chạm",
      "⏸️ Nút Để Sau & Banner cố định nhắc nhở cập nhật nhanh khi đã đóng popup"
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
