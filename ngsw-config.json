{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.23-b23",
    "notesVersion": "v26.07.23-b23",
    "title": "SmartBatch: Sửa Mẻ Nhanh & Tối Ưu Tốc Độ",
    "features": [
      "⚡ Mở màn hình nhanh hơn nhờ tải thư viện nặng khi thật sự cần",
      "🧪 SmartBatch là luồng chính; SOP Calculator chuyển thành nút tính nhanh trong SmartBatch",
      "✏️ Sửa mẻ trực tiếp từ Hàng đợi In, Quản lý Yêu cầu và Daily Checklist trên Dashboard",
      "🖨️ Sau khi duyệt mẻ, phiếu được đưa vào Hàng đợi In; không bật hộp thoại in ngay"
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
