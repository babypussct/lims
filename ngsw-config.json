{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.21-b02",
    "title": "Cập nhật Hệ thống LIMS",
    "features": [
      "Áp dụng cơ chế cập nhật tự động không gián đoạn.",
      "Tối ưu hóa hiệu năng phản hồi của giao diện thông báo.",
      "Cải thiện độ ổn định trong luồng định tuyến thiết bị ngoại vi.",
      "Nâng cấp kiến trúc giao diện theo tiêu chuẩn Enterprise."
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
