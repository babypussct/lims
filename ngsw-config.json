{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.24-b25",
    "notesVersion": "v26.07.24-b25",
    "title": "Daily Checklist Dễ Xem Hơn, Dashboard Có Nhật Ký Hơn",
    "features": [
      "📋 Mẫu có tiền tố được xếp trước mẫu không tiền tố trong Daily Checklist",
      "👤 Nhân viên không còn bị trắng mục Hoạt Động Gần Đây",
      "🖨️ Bỏ tạo QR khi in Daily Checklist để thao tác nhẹ và ổn định hơn"
