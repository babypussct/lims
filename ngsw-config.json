{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "v26.07.24-b02",
    "notesVersion": "v26.07.24-b02",
    "title": "Nâng Cấp Đếm Ngược Cập Nhật & Nút Để Sau",
    "features": [
      "⏳ Đếm ngược 30s tự động tạm dừng ở 10s nếu máy không tương tác, tiếp tục đếm khi di chuột/chạm",
      "⏸️ Thêm nút Để Sau cho phép bỏ qua cập nhật tạm thời",
      "🔔 Banner thông báo cố định nhắc nhở cập nhật nhanh khi đã đóng popup"
    ]
  },
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/main-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "feature-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
