{
  "buildCommand": "npx ng build --configuration=production --no-progress",
  "outputDirectory": "dist/lims-cloud-pro/browser",
  "framework": "angular",
  "rewrites": [
    { "source": "/__/auth/(.*)", "destination": "https://lims-cloud-by-otada.firebaseapp.com/__/auth/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/main-(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/chunk-(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles-(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/ngsw.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, no-transform" }
      ]
    },
    {
      "source": "/ngsw-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, no-transform" }
      ]
    },
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, no-transform" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, no-transform" }
      ]
    }
  ]
}
