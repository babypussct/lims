rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Hàm kiểm tra người dùng đã đăng nhập chưa
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Kiểm tra tài liệu User Profile có tồn tại không
    function userExists(appId) {
      return isSignedIn() && exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid));
    }

    // 3. Lấy tài liệu User Profile của request hiện tại
    function getUserProfile(appId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data;
    }

    // 4. Kiểm tra User có phải là Manager không
    function isManager(appId) {
      return userExists(appId) && getUserProfile(appId).get('role', 'pending') == 'manager';
    }

    // 5. Trợ giúp phân giải quyền hạn khi tài liệu người dùng được xác định là tồn tại
    function evaluateUserPermission(appId, profile, permission) {
      let role = profile.get('role', 'pending');
      let rawRoleId = profile.get('roleId', 'role_staff_default');
      let roleId = (rawRoleId == null || rawRoleId == '') ? 'role_staff_default' : rawRoleId;
      let directPerms = profile.get('permissions', []);
      let overridePerms = profile.get('customPermissions', []);
      let hasCustom =
        (directPerms is list && directPerms.hasAny([permission])) ||
        (overridePerms is list && overridePerms.hasAny([permission]));
      
      return role == 'manager' || 
        (
          role == 'viewer' && 
          ['inventory_view', 'standard_view', 'sop_view', 'recipe_view'].hasAny([permission])
        ) ||
        hasCustom ||
        (
          role == 'staff' &&
          (
            // 1. Ưu tiên cao nhất: Nếu manager đã cấu hình roles_config thì lấy theo cấu hình đó
            (
              exists(/databases/$(database)/documents/artifacts/$(appId)/roles_config/$(roleId)) &&
              'permissions' in get(/databases/$(database)/documents/artifacts/$(appId)/roles_config/$(roleId)).data &&
              get(/databases/$(database)/documents/artifacts/$(appId)/roles_config/$(roleId)).data.permissions is list &&
              get(/databases/$(database)/documents/artifacts/$(appId)/roles_config/$(roleId)).data.permissions.hasAny([permission])
            )
            ||
            // 2. Fallback: CHỈ ÁP DỤNG khi roles_config chưa được tạo (bị trống)
            (
              !exists(/databases/$(database)/documents/artifacts/$(appId)/roles_config/$(roleId)) &&
              (
                ['inventory_view', 'standard_view', 'sop_view', 'recipe_view', 'standard_request'].hasAny([permission]) ||
                (roleId == 'role_lab_technician' && ['inventory_edit', 'batch_run'].hasAny([permission])) ||
                (roleId == 'role_qc_lead' && ['inventory_edit', 'standard_edit', 'standard_approve', 'standard_log_view', 'standard_log_delete', 'recipe_edit', 'sop_edit', 'sop_approve', 'batch_run', 'report_view'].hasAny([permission]))
              )
            )
          )
        );
    }

    // 6. Kiểm tra User có một quyền cụ thể nào đó không (Tuyệt đối không gây crash nếu user profile chưa tồn tại)
    function hasPermission(appId, permission) {
      return userExists(appId) && evaluateUserPermission(appId, getUserProfile(appId), permission);
    }

    function canOperateStandards(appId) {
      return hasPermission(appId, 'standard_edit') || hasPermission(appId, 'standard_approve');
    }

    function canRollbackStandardLogs(appId) {
      return hasPermission(appId, 'standard_edit') || hasPermission(appId, 'standard_log_delete');
    }

    // --- CẤU HÌNH HỆ THỐNG VÀ VAI TRÒ ---
    
    // Mọi người dùng đã đăng nhập đều có thể đọc thông tin cơ bản để hiển thị avatar,
    // nhưng chỉ người dùng đó hoặc Manager mới được phép chỉnh sửa
    match /artifacts/{appId}/users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.role == 'pending' &&
        request.resource.data.get('permissions', []).size() == 0;
      allow update: if isManager(appId) || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'photoURL', 'avatarStyle', 'fcmTokens', 'email', 'displayName', 'lastSeen', 'lastLogin'
        ])
      );
      allow delete: if isManager(appId);
    }

    // Cấu hình nhóm vai trò động (Roles Config)
    match /artifacts/{appId}/roles_config/{roleId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId);
    }

    // Metadata hệ thống và Cấu hình chung
    match /artifacts/{appId}/system/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId);
    }
    match /artifacts/{appId}/config/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId);
    }
    match /artifacts/{appId}/sample_description_master/{itemId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId) || hasPermission(appId, 'sop_edit');
    }
    match /artifacts/{appId}/system_updates/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId);
    }
    match /artifacts/{appId}/stats/{docId} {
      allow read, write: if isSignedIn();
    }
    match /artifacts/{appId}/notifications/{docId} {
      allow read, write: if isSignedIn();
    }
    match /artifacts/{appId}/auth_sessions/{sessionId} {
      allow read, write: if true;
    }

    // --- CÁC MODULE NGHIỆP VỤ ---

    // MODULE KHO (INVENTORY)
    match /artifacts/{appId}/inventory/{itemId} {
      allow read: if hasPermission(appId, 'inventory_view');
      allow write: if hasPermission(appId, 'inventory_edit');
      
      // Lịch sử tiêu hao / thay đổi kho
      match /history/{histId} {
        allow read: if hasPermission(appId, 'inventory_view');
        allow write: if hasPermission(appId, 'inventory_edit');
      }
    }

    // MODULE CHUẨN ĐỐI CHIẾU (REFERENCE STANDARDS)
    match /artifacts/{appId}/reference_standards/{stdId} {
      allow read: if hasPermission(appId, 'standard_view');
      allow create: if hasPermission(appId, 'standard_edit');
      allow update: if hasPermission(appId, 'standard_edit') 
        || (
          hasPermission(appId, 'standard_approve') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'current_holder', 'current_holder_uid', 'current_request_id',
            'has_pending_request', 'restock_requested', 'current_amount', 'date_opened', 'lastUpdated'
          ]) &&
          request.resource.data.current_amount >= 0
        )
        || (
          hasPermission(appId, 'standard_request') && (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['has_pending_request', 'lastUpdated']) &&
              request.resource.data.has_pending_request == true
            )
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['restock_requested', 'lastUpdated']) &&
              request.resource.data.restock_requested == true
            )
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coa_requested_by', 'lastUpdated']) &&
              request.resource.data.coa_requested_by == request.auth.uid
            )
            || (
              resource.data.current_holder_uid == request.auth.uid &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'current_amount', 'date_opened', 'lastUpdated']) &&
              request.resource.data.current_amount >= 0 &&
              request.resource.data.current_amount <= resource.data.current_amount &&
              ['IN_USE', 'DEPLETED'].hasAny([request.resource.data.status])
            )
          )
        )
        || (
          hasPermission(appId, 'standard_log_delete') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'current_holder', 'current_holder_uid', 'current_request_id',
            'has_pending_request', 'current_amount', 'lastUpdated'
          ]) &&
          request.resource.data.current_amount >= resource.data.current_amount
        );
      allow delete: if hasPermission(appId, 'standard_delete') || isManager(appId);

      // Nhật ký mượn/sử dụng chất chuẩn chi tiết
      match /logs/{logId} {
        allow read: if hasPermission(appId, 'standard_view');
        allow create: if canOperateStandards(appId) || (
          hasPermission(appId, 'standard_request') &&
          get(/databases/$(database)/documents/artifacts/$(appId)/reference_standards/$(stdId)).data.current_holder_uid == request.auth.uid &&
          request.resource.data.standardId == stdId &&
          request.resource.data.amount_used > 0
        );
        allow update: if canRollbackStandardLogs(appId);
        allow delete: if false;
      }
    }

    // Yêu cầu mua chuẩn (Purchase/Standard Requests)
    match /artifacts/{appId}/standard_requests/{reqId} {
      allow read: if canOperateStandards(appId) || hasPermission(appId, 'standard_log_view') ||
        hasPermission(appId, 'standard_log_delete') || (
        isSignedIn() && resource.data.requestedBy == request.auth.uid
      );
      allow create: if canOperateStandards(appId) || (
        hasPermission(appId, 'standard_request') &&
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.status == 'PENDING_APPROVAL' &&
        request.resource.data.totalAmountUsed == 0
      );
      allow update: if canOperateStandards(appId) || (
        hasPermission(appId, 'standard_log_delete') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          '_isDeleted', 'status', 'usageLogs', 'totalAmountUsed',
          'rolledBackAt', 'rolledBackBy', 'updatedAt', 'lastUpdated'
        ]) &&
        request.resource.data.totalAmountUsed <= resource.data.totalAmountUsed
      ) || (
        hasPermission(appId, 'standard_request') &&
        resource.data.requestedBy == request.auth.uid &&
        request.resource.data.requestedBy == resource.data.requestedBy &&
        request.resource.data.standardId == resource.data.standardId &&
        request.resource.data.totalAmountUsed >= 0 &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'totalAmountUsed', 'reportedDepleted', 'usageLogs', 'updatedAt', 'lastUpdated'
        ]) && (
          (
            request.resource.data.status == resource.data.status &&
            ['PENDING_APPROVAL', 'IN_PROGRESS', 'PENDING_RETURN', 'PENDING_DEPLETION'].hasAny([resource.data.status])
          ) ||
          (resource.data.status == 'IN_PROGRESS' && request.resource.data.status == 'PENDING_RETURN') ||
          (resource.data.status == 'PENDING_RETURN' && request.resource.data.status == 'IN_PROGRESS') ||
          (resource.data.status == 'PENDING_DEPLETION' && request.resource.data.status == 'IN_PROGRESS')
        )
      );
      allow delete: if false;
    }
    match /artifacts/{appId}/purchase_requests/{reqId} {
      allow read: if canOperateStandards(appId) || (
        isSignedIn() && resource.data.requestedBy == request.auth.uid
      );
      allow create: if canOperateStandards(appId) || (
        hasPermission(appId, 'standard_request') &&
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.status == 'PENDING'
      );
      allow update: if canOperateStandards(appId);
      allow delete: if false;
    }

    // Lịch sử sử dụng chuẩn chung
    match /artifacts/{appId}/standard_usages/{useId} {
      allow read: if hasPermission(appId, 'standard_log_view') ||
        hasPermission(appId, 'standard_log_delete') || canOperateStandards(appId);
      allow create: if canOperateStandards(appId) || (
        hasPermission(appId, 'standard_request') &&
        request.resource.data.requestId is string &&
        get(/databases/$(database)/documents/artifacts/$(appId)/standard_requests/$(request.resource.data.requestId)).data.requestedBy == request.auth.uid &&
        request.resource.data.amount_used > 0
      );
      allow update: if canRollbackStandardLogs(appId);
      allow delete: if false;
    }

    // MODULE QUY TRÌNH SOP & CÔNG THỨC (SOPS & RECIPES)
    match /artifacts/{appId}/sops/{sopId} {
      allow read: if hasPermission(appId, 'sop_view');
      allow write: if hasPermission(appId, 'sop_edit');

      match /history/{histId} {
        allow read: if hasPermission(appId, 'sop_view');
        allow write: if hasPermission(appId, 'sop_edit');
      }
    }
    match /artifacts/{appId}/recipes/{recipeId} {
      allow read: if hasPermission(appId, 'recipe_view');
      allow write: if hasPermission(appId, 'recipe_edit');
    }

    // MODULE YÊU CẦU KIỂM NGHIỆM VÀ KẾT QUẢ (REQUESTS)
    match /artifacts/{appId}/requests/{reqId} {
      allow get: if true; // Public read cho phép truy xuất kết quả/QR code không cần đăng nhập
      allow list: if isSignedIn();
      allow write: if isManager(appId) || hasPermission(appId, 'batch_run');

      match /history/{histId} {
        allow read: if isSignedIn();
        allow write: if isManager(appId) || hasPermission(appId, 'batch_run');
      }
    }
    match /artifacts/{appId}/results_details/{docId} {
      allow read, write: if isSignedIn();
    }

    // Yêu cầu in ấn nhãn / barcode (Print Jobs)
    match /artifacts/{appId}/print_jobs/{jobId} {
      allow read: if true; // Public read cho phép máy in hoặc client quét barcode không cần login
      allow write: if isSignedIn();
    }

    // Thư viện Target Master
    match /artifacts/{appId}/target_groups/{tgId} {
      allow read: if isSignedIn();
      allow write: if isManager(appId) || hasPermission(appId, 'sop_edit');
    }
    match /artifacts/{appId}/master_targets/{docId} {
      allow read, write: if isSignedIn();
    }
    match /artifacts/{appId}/master_analytes/{docId} {
      allow read, write: if isSignedIn();
    }
    match /artifacts/{appId}/matrix_types/{docId} {
      allow read, write: if isSignedIn();
    }
    match /artifacts/{appId}/master_devices/{docId} {
      allow read, write: if isSignedIn();
    }

    // Lịch sử Audit Trail / Nhật ký hệ thống chung (Logs)
    match /artifacts/{appId}/logs/{logId} {
      allow create: if isSignedIn();
      allow get: if true; // Public read cho phép quét QR code truy xuất nguồn gốc
      allow list: if isSignedIn();
      allow update, delete: if isManager(appId);
    }
  }
}
