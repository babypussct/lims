{
  "id": "9.14-tbvtv-gcmsms",
  "category": "TBVTV",
  "name": "Xác định dư lượng TBVTV – GC-MS/MS (USDA)",
  "ref": "AOAC 2007.01; CLG-PST5.07; CLG-PST5.08; CLG-PST5.09; CLG-PST5.10",
  "version": 4,
  "matrixTags": ["food"],
  "device": "GC-MS/MS",
  "allowedDevices": ["GC-MS/MS"],
  "inputs": [
    { "var": "n_sample", "label": "Số lượng mẫu thử", "type": "number", "default": 1, "step": 1, "unitLabel": "mẫu" },
    { "var": "n_qc", "label": "Số lượng QC (kiểm soát)", "type": "number", "default": 8, "step": 1, "unitLabel": "mẫu" },
    { "var": "w_sample", "label": "Khối lượng mẫu", "type": "number", "default": 10, "step": 0.1, "unitLabel": "g" }
  ],
  "variables": {
    "total_n": "n_sample + n_qc",
    "total_vol_acn": "total_n * 10",
    "total_vol_is": "total_n * 0.02"
  },
  "consumables": [
    { "name": "acetonitrile", "type": "simple", "_displayName": "Acetonitrile (ACN) đã acid hoá 1%", "formula": "total_n * 10 * 1.1", "unit": "ml", "base_note": "Dung môi chiết (6.1)", "ingredients": [] },
    { "name": "mgso4",       "type": "simple", "_displayName": "MgSO4 khan (Hỗn hợp muối A)",        "formula": "total_n * 4.5 * 1.1", "unit": "g",  "base_note": "Hỗn hợp A (6.2) – 4.5g/mẫu", "ingredients": [] },
    { "name": "sodium_acetate", "type": "simple", "_displayName": "Sodium acetate (NaOAc) khan",    "formula": "total_n * 1.0 * 1.1", "unit": "g",  "base_note": "Hỗn hợp A (6.2) – 1.0g/mẫu", "ingredients": [] },
    { "name": "mgso4_cleanup","type": "simple", "_displayName": "MgSO4 khan (Làm sạch B)",          "formula": "total_n * 1.2 * 1.1", "unit": "g",  "base_note": "Hỗn hợp B (6.3) – 1.2g/mẫu", "ingredients": [] },
    { "name": "psa_powder",  "type": "simple", "_displayName": "Bột PSA (Làm sạch B)",              "formula": "total_n * 0.5 * 1.1", "unit": "g",  "base_note": "Hỗn hợp B (6.3) – 0.5g/mẫu", "ingredients": [] },
    { "name": "c18_powder",  "type": "simple", "_displayName": "Bột C18 (Làm sạch B)",              "formula": "total_n * 0.5 * 1.1", "unit": "g",  "base_note": "Hỗn hợp B (6.3) – 0.5g/mẫu", "ingredients": [] },
    { "name": "toluene",     "type": "simple", "_displayName": "Toluene (pha mẫu phân tích)",       "formula": "total_n * 0.1 * 1.2", "unit": "ml", "base_note": "100µl/lọ (bước 8.4)", "ingredients": [] },
    { "name": "is_solution_working", "type": "simple", "_displayName": "Dung dịch nội chuẩn IS (6.4)", "formula": "total_n * 0.02 * 1.2", "unit": "ml", "base_note": "20µl/mẫu – Dichlorvos D6, Chlorpyrifos D10, Fipronil 13C215N2", "ingredients": [] }
  ],
  "targets": [
    { "id": "1-naphthol",                        "name": "1-Naphthol",                          "unit": "ppb", "loq": "5 ppb" },
